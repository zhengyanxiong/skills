{
  "skill_name": "skill-authoring-guide",
  "assertions": [
    {
      "id": "A1",
      "description": "生成的 Skill 包含正确的 YAML frontmatter（name、description 必填）",
      "type": "structure",
      "weight": 1.0
    },
    {
      "id": "A2",
      "description": "description 包含触发关键词，覆盖多种用户表述，适当强势",
      "type": "correctness",
      "weight": 1.0
    },
    {
      "id": "A3",
      "description": "使用了三层渐进式加载（L1/L2/L3）",
      "type": "structure",
      "weight": 1.0
    },
    {
      "id": "A4",
      "description": "解释了设计原则（为什么这样设计），而非堆砌必须",
