#!/usr/bin/env bash
# skills - Python availability check + delegate to skills.py
#
# Usage:
#   ./skills list                         Show current link state
#   ./skills install                      Create/update symlinks for all skills
#   ./skills uninstall                    Remove symlinks
#   ./skills status                       Show current link state
#   ./skills install --dry-run            Preview without executing
#   ./skills install --agents claude-code,kimi
#   ./skills install --skills skill-authoring-guide
#
# All real logic lives in skills.py. This script only ensures Python
# is available before delegating.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# ── Colors ────────────────────────────────────────────────────────────────

BOLD='\033[1m'
DIM='\033[2m'
GREEN='\033[32m'
YELLOW='\033[33m'
RED='\033[31m'
CYAN='\033[36m'
RESET='\033[0m'

err() { echo -e "  ${RED}${BOLD}[XX]${RESET} $*"; }

# ── Python check ──────────────────────────────────────────────────────────

check_python() {
  if command -v python3 &>/dev/null; then
    PYTHON=python3
    return 0
  fi
  if command -v python &>/dev/null; then
    PYTHON=python
    return 0
  fi

  echo ""
  echo -e "${YELLOW}${BOLD}⚠  Python is not installed on this system.${RESET}"
  echo ""
  echo -e "  ${CYAN}[m] Manual${RESET} - show install instructions and exit"
  echo -e "  ${GREEN}[a] Auto${RESET}   - install Python via uv"
  echo -e "  ${RED}[q] Quit${RESET}"
  echo ""
  read -rp "$(echo -e ${CYAN})Choose (m/a/q, default: q): $(echo -e ${RESET})" choice
  choice="${choice,,}"

  case "$choice" in
    m)
      echo ""
      echo -e "${CYAN}Install Python 3.11+ using your package manager:${RESET}"
      echo "  Debian/Ubuntu: sudo apt install python3 python3-pip python3-venv"
      echo "  RHEL/Fedora:   sudo dnf install python3 python3-pip"
      echo "  Arch:          sudo pacman -S python python-pip"
      echo "  macOS:         brew install python@3.12"
      echo ""
      echo -e "${CYAN}Or download from https://www.python.org/downloads/${RESET}"
      exit 1
      ;;
    a)
      echo -e "${GREEN}Installing Python via uv...${RESET}"

      if ! command -v uv &>/dev/null; then
        echo -e "${YELLOW}uv not found. Installing uv first...${RESET}"
        if command -v curl &>/dev/null; then
          curl -LsSf https://astral.sh/uv/install.sh | sh
        elif command -v wget &>/dev/null; then
          wget -qO- https://astral.sh/uv/install.sh | sh
        else
          err "Neither curl nor wget found. Install uv manually: https://docs.astral.sh/uv/"
          exit 1
        fi
        export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
        if ! command -v uv &>/dev/null; then
          err "uv installation failed. Please install Python manually."
          exit 1
        fi
        echo -e "  ${GREEN}[OK]${RESET} uv installed"
      fi

      echo -e "${DIM}Running: uv python install 3.12${RESET}"
      uv python install 3.12

      # After install, uv-managed python is findable via `uv run` or explicit path;
      # fall back to checking python3 again in case uv linked it into PATH.
      if command -v python3 &>/dev/null; then
        PYTHON=python3
        echo -e "  ${GREEN}[OK]${RESET} Python 3.12 installed via uv"
        return 0
      fi

      err "Python installation via uv failed. Install manually."
      exit 1
      ;;
    *)
      echo -e "${RED}Exiting.${RESET}"
      exit 1
      ;;
  esac
}

check_python
exec "$PYTHON" "$SCRIPT_DIR/skills.py" "$@"
